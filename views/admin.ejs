<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - CinemaPro</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.min.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #e50914;
            --secondary-color: #221f1f;
            --accent-color: #f39c12;
        }

        * {
            scroll-behavior: smooth;
        }

        body {
            background-color: #0f0f0f;
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Navbar Styling */
        .navbar {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border-bottom: 3px solid var(--primary-color);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
            color: var(--primary-color) !important;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .nav-link {
            color: #e0e0e0 !important;
            margin-left: 15px;
            transition: color 0.3s ease;
        }

        .nav-link:hover {
            color: var(--primary-color) !important;
        }

        /* Admin Header */
        .admin-header {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            padding: 40px 0;
            border-bottom: 2px solid var(--primary-color);
            margin-bottom: 40px;
        }

        .admin-header h1 {
            color: var(--primary-color);
            font-weight: bold;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .admin-header p {
            color: #b0b0b0;
        }

        /* Tabs */
        .nav-tabs {
            border-bottom: 2px solid var(--primary-color);
        }

        .nav-tabs .nav-link {
            color: #b0b0b0;
            border: none;
            border-bottom: 3px solid transparent;
            transition: all 0.3s ease;
        }

        .nav-tabs .nav-link:hover {
            color: var(--primary-color);
            border-bottom-color: var(--primary-color);
        }

        .nav-tabs .nav-link.active {
            background-color: transparent;
            color: var(--primary-color);
            border-bottom: 3px solid var(--primary-color);
        }

        /* Table Styles */
        .table {
            color: #e0e0e0;
        }

        .table thead {
            background-color: #1a1a1a;
            border-bottom: 2px solid var(--primary-color);
        }

        .table thead th {
            color: var(--primary-color);
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: none;
        }

        .table tbody tr {
            border-bottom: 1px solid #404040;
            transition: all 0.3s ease;
        }

        .table tbody tr:hover {
            background-color: #2d2d2d;
        }

        .table tbody td {
            vertical-align: middle;
            border-color: #404040;
        }

        /* Forms */
        .form-control, .form-select {
            background-color: #2d2d2d;
            border: 1px solid #404040;
            color: #e0e0e0;
        }

        .form-control:focus, .form-select:focus {
            background-color: #2d2d2d;
            border-color: var(--primary-color);
            color: #e0e0e0;
            box-shadow: 0 0 0 0.2rem rgba(229, 9, 20, 0.25);
        }

        .form-label {
            color: #e0e0e0;
            font-weight: 500;
            margin-bottom: 8px;
        }

        /* Modal */
        .modal-content {
            background-color: #1a1a1a;
            border: 2px solid #404040;
        }

        .modal-header {
            border-bottom: 2px solid var(--primary-color);
            background-color: #2d2d2d;
        }

        .modal-title {
            color: var(--primary-color);
            font-weight: bold;
        }

        .btn-close {
            filter: invert(1);
        }

        /* Buttons */
        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            font-weight: bold;
        }

        .btn-primary:hover {
            background-color: #c40812;
        }

        .btn-danger {
            background-color: #d32f2f;
            border: none;
        }

        .btn-danger:hover {
            background-color: #b71c1c;
        }

        .btn-warning {
            background-color: var(--accent-color);
            border: none;
            color: #000;
        }

        .btn-warning:hover {
            background-color: #e68900;
        }

        /* Stats Card */
        .stat-card {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border: 2px solid #404040;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            text-align: center;
        }

        .stat-card h3 {
            color: #b0b0b0;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .stat-card .stat-value {
            color: var(--primary-color);
            font-size: 2.5rem;
            font-weight: bold;
        }

        /* Footer */
        footer {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border-top: 2px solid var(--primary-color);
            padding: 30px 0;
            margin-top: 50px;
            text-align: center;
            color: #b0b0b0;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .admin-header {
                padding: 20px 0;
            }

            .admin-header h1 {
                font-size: 1.8rem;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">🎬 CinemaPro</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#movies">Movies</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/admin">Admin</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="admin-header">
        <div class="container">
            <h1>🎬 Admin Dashboard</h1>
            <p>Manage movies, view bookings, and control your cinema operations</p>
        </div>
    </div>

    <div class="container mb-5">
        <!-- Stats Row -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="stat-card">
                    <h3>📽️ Total Movies</h3>
                    <div class="stat-value"><%= movies.length %></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="stat-card">
                    <h3>🎟️ Total Bookings</h3>
                    <div class="stat-value"><%= bookings.length %></div>
                </div>
            </div>
        </div>

        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="movies-tab" data-bs-toggle="tab" data-bs-target="#movies" type="button" role="tab">
                    📽️ Movies Management
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="bookings-tab" data-bs-toggle="tab" data-bs-target="#bookings" type="button" role="tab">
                    🎟️ View Bookings
                </button>
            </li>
        </ul>

        <div class="tab-content mt-4">
            <div class="tab-pane fade show active" id="movies" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 style="color: var(--primary-color); font-weight: bold;">All Movies</h2>
                    <button class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#addMovieModal">
                        <i class="fas fa-plus"></i> Add New Movie
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>Genre</th>
                                <th>Duration</th>
                                <th>Rating</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% movies.forEach(movie => { %>
                                <tr>
                                    <td><span class="badge" style="background-color: var(--primary-color);"><%= movie.id %></span></td>
                                    <td><strong><%= movie.title %></strong></td>
                                    <td><%= movie.genre %></td>
                                    <td><%= movie.duration %></td>
                                    <td><%= movie.rating %></td>
                                    <td>
                                        <button class="btn btn-danger btn-sm" onclick="deleteMovie(<%= movie.id %>, '<%= movie.title %>')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>

                    <% if (movies.length === 0) { %>
                        <div class="alert alert-info text-center" style="background-color: #2d2d2d; border: 2px solid var(--primary-color); color: var(--primary-color);">
                            <strong>No movies available.</strong> Click "Add New Movie" to add your first movie!
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="tab-pane fade" id="bookings" role="tabpanel">
                <h2 style="color: var(--primary-color); font-weight: bold; margin-bottom: 30px;">Booking Records</h2>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Movie</th>
                                <th>Seats</th>
                                <th>Total</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% bookings.forEach(booking => { %>
                                <tr>
                                    <td><span class="badge" style="background-color: var(--primary-color);">BOOK-<%= String(booking.id).padStart(5, '0') %></span></td>
                                    <td><strong><%= booking.name %></strong></td>
                                    <td><%= booking.email %></td>
                                    <td><%= booking.movieTitle %></td>
                                    <td><strong><%= booking.seats %></strong></td>
                                    <td style="color: var(--primary-color); font-weight: bold;">$<%= (booking.seats * 12 * 1.1).toFixed(2) %></td>
                                    <td><%= booking.bookingDate %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>

                    <% if (bookings.length === 0) { %>
                        <div class="alert alert-info text-center" style="background-color: #2d2d2d; border: 2px solid var(--primary-color); color: var(--primary-color);">
                            <strong>No bookings yet.</strong> Bookings will appear here once customers start booking tickets.
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addMovieModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title">Add New Movie</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="addMovieForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="movieTitle" class="form-label">Movie Title <span style="color: var(--primary-color);">*</span></label>
                            <input type="text" class="form-control" id="movieTitle" name="title" placeholder="Enter movie title" required>
                        </div>
                        <div class="mb-3">
                            <label for="movieGenre" class="form-label">Genre <span style="color: var(--primary-color);">*</span></label>
                            <input type="text" class="form-control" id="movieGenre" name="genre" placeholder="e.g., Action, Drama" required>
                        </div>
                        <div class="mb-3">
                            <label for="movieDuration" class="form-label">Duration <span style="color: var(--primary-color);">*</span></label>
                            <input type="text" class="form-control" id="movieDuration" name="duration" placeholder="e.g., 120 min" required>
                        </div>
                        <div class="mb-3">
                            <label for="movieRating" class="form-label">IMDB Rating <span style="color: var(--primary-color);">*</span></label>
                            <input type="text" class="form-control" id="movieRating" name="rating" placeholder="e.g., 8.5/10" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Movie</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <footer>
        <div class="container">
            <p>&copy; 2026 CinemaPro. All Rights Reserved. | Enjoy Your Movie Experience! 🍿</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.all.min.js"></script>

    <script>
        const addMovieForm = document.getElementById('addMovieForm');
        const addMovieModal = new bootstrap.Modal(document.getElementById('addMovieModal'));

        addMovieForm.addEventListener('submit', async function(e) {
            e.preventDefault();

            const title = document.getElementById('movieTitle').value;
            const genre = document.getElementById('movieGenre').value;
            const duration = document.getElementById('movieDuration').value;
            const rating = document.getElementById('movieRating').value;

            try {
                const response = await fetch('/api/movie', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        title: title,
                        genre: genre,
                        duration: duration,
                        rating: rating
                    })
                });

                const data = await response.json();

                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Movie Added!',
                        text: 'The movie has been added successfully.',
                        background: '#1a1a1a',
                        color: '#e0e0e0',
                        confirmButtonColor: '#e50914',
                        didClose: () => {
                            location.reload();
                        }
                    });
                    addMovieModal.hide();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: data.message || 'Failed to add movie.',
                        background: '#1a1a1a',
                        color: '#e0e0e0',
                        confirmButtonColor: '#e50914'
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An unexpected error occurred.',
                    background: '#1a1a1a',
                    color: '#e0e0e0',
                    confirmButtonColor: '#e50914'
                });
            }
        });

        // Delete Movie Function
        function deleteMovie(movieId, movieTitle) {
            Swal.fire({
                title: 'Delete Movie?',
                text: `Are you sure you want to delete "${movieTitle}"? This action cannot be undone.`,
                icon: 'warning',
                background: '#1a1a1a',
                color: '#e0e0e0',
                showCancelButton: true,
                confirmButtonColor: '#d32f2f',
                cancelButtonColor: '#404040',
                confirmButtonText: 'Yes, Delete It!',
                cancelButtonText: 'Cancel'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const response = await fetch(`/api/movie/${movieId}`, {
                            method: 'DELETE'
                        });

                        const data = await response.json();

                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Deleted!',
                                text: 'The movie has been deleted successfully.',
                                background: '#1a1a1a',
                                color: '#e0e0e0',
                                confirmButtonColor: '#e50914',
                                didClose: () => {
                                    location.reload();
                                }
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'Failed to delete the movie.',
                                background: '#1a1a1a',
                                color: '#e0e0e0',
                                confirmButtonColor: '#e50914'
                            });
                        }
                    } catch (error) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'An unexpected error occurred.',
                            background: '#1a1a1a',
                            color: '#e0e0e0',
                            confirmButtonColor: '#e50914'
                        });
                    }
                }
            });
        }
    </script>
</body>
</html>
