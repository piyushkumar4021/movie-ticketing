<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — CinemaPro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --cp-red:#e50914;--cp-red-dark:#b0060f;--cp-gold:#f6c700;
            --cp-dark:#0a0a0f;--cp-card:#14141f;--cp-surface:#1c1c2b;
            --cp-border:rgba(255,255,255,.06);--cp-text:#e2e2e8;--cp-muted:#8b8b9e;
        }
        *{margin:0;padding:0;box-sizing:border-box}
        body{
            background:var(--cp-dark);color:var(--cp-text);font-family:'Inter',sans-serif;
            min-height:100vh;display:flex;align-items:center;justify-content:center;
            position:relative;overflow:hidden;
        }
        h1,h2,h3,h4{font-family:'Outfit',sans-serif}

        .bg-glow{
            position:absolute;width:400px;height:400px;border-radius:50%;
            filter:blur(120px);opacity:.08;pointer-events:none;
        }
        .bg-glow.g1{background:var(--cp-red);top:-100px;left:-100px}
        .bg-glow.g2{background:var(--cp-gold);bottom:-100px;right:-100px}

        .auth-card{
            position:relative;z-index:1;
            background:var(--cp-card);border:1px solid var(--cp-border);
            border-radius:24px;padding:3rem 2.5rem;width:100%;max-width:440px;
            box-shadow:0 16px 60px rgba(0,0,0,.5);
        }
        .auth-card .brand{
            text-align:center;margin-bottom:2rem;
        }
        .brand-logo{
            font-family:'Outfit',sans-serif;font-weight:900;font-size:1.8rem;
            background:linear-gradient(135deg,var(--cp-red),var(--cp-gold));
            -webkit-background-clip:text;-webkit-text-fill-color:transparent;
            letter-spacing:1.5px;
        }
        .brand p{color:var(--cp-muted);font-size:.9rem;margin-top:.3rem}

        .auth-title{text-align:center;font-weight:700;font-size:1.5rem;color:#fff;margin-bottom:.3rem}
        .auth-subtitle{text-align:center;color:var(--cp-muted);font-size:.9rem;margin-bottom:2rem}

        .form-floating>.form-control{
            background:var(--cp-surface);border:1px solid var(--cp-border);
            color:var(--cp-text);border-radius:12px;height:52px;
        }
        .form-floating>.form-control:focus{
            border-color:var(--cp-red);box-shadow:0 0 0 3px rgba(229,9,20,.15);
            background:var(--cp-surface);color:var(--cp-text);
        }
        .form-floating label{color:var(--cp-muted);font-size:.9rem}

        .btn-auth{
            background:linear-gradient(135deg,var(--cp-red),var(--cp-red-dark));
            color:#fff;border:none;border-radius:12px;padding:.85rem;
            font-weight:700;font-size:1rem;width:100%;
            transition:all .25s;box-shadow:0 4px 20px rgba(229,9,20,.3);
        }
        .btn-auth:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(229,9,20,.5);color:#fff}

        .auth-footer{text-align:center;margin-top:1.5rem;font-size:.9rem;color:var(--cp-muted)}
        .auth-footer a{color:var(--cp-red);text-decoration:none;font-weight:600;transition:color .2s}
        .auth-footer a:hover{color:var(--cp-gold)}

        .alert-error{
            background:rgba(229,9,20,.1);border:1px solid rgba(229,9,20,.25);
            border-radius:10px;padding:.8rem 1rem;color:#ff6b6b;
            font-size:.88rem;margin-bottom:1.2rem;text-align:center;
        }

        .divider{display:flex;align-items:center;gap:1rem;margin:1.5rem 0;color:var(--cp-muted);font-size:.82rem}
        .divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--cp-border)}

        .demo-accounts{
            background:var(--cp-surface);border:1px solid var(--cp-border);border-radius:10px;
            padding:.9rem 1rem;font-size:.78rem;color:var(--cp-muted);
        }
        .demo-accounts strong{color:var(--cp-text)}
        .demo-accounts .demo-row{display:flex;justify-content:space-between;margin-top:.3rem;gap:.5rem}

        .back-home{
            position:absolute;top:1.5rem;left:1.5rem;z-index:2;
            color:var(--cp-muted);text-decoration:none;font-size:.9rem;
            display:flex;align-items:center;gap:.3rem;transition:color .2s;
        }
        .back-home:hover{color:#fff}

        @media(max-width:480px){
            .auth-card{margin:1rem;padding:2rem 1.5rem}
        }
    </style>
</head>
<body>
    <div class="bg-glow g1"></div>
    <div class="bg-glow g2"></div>

    <a href="/" class="back-home"><i class="bi bi-arrow-left"></i> Home</a>

    <div class="auth-card">
        <div class="brand">
            <div class="brand-logo"><i class="bi bi-film"></i> CinemaPro</div>
            <p>Your premium cinema experience</p>
        </div>

        <h2 class="auth-title">Welcome Back</h2>
        <p class="auth-subtitle">Sign in to book your favourite movies</p>

        <% if (error) { %>
            <div class="alert-error"><i class="bi bi-exclamation-circle-fill me-1"></i> <%= error %></div>
        <% } %>

        <form method="POST" action="/login" id="loginForm">
            <div class="form-floating mb-3">
                <input type="email" class="form-control" id="email" name="email" placeholder="Email" required>
                <label for="email"><i class="bi bi-envelope-fill me-1"></i> Email</label>
            </div>
            <div class="form-floating mb-4">
                <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
                <label for="password"><i class="bi bi-lock-fill me-1"></i> Password</label>
            </div>
            <button type="submit" class="btn btn-auth">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </button>
        </form>

        <div class="auth-footer">
            Don't have an account? <a href="/register">Create one</a>
        </div>

        <div class="divider">Demo Accounts</div>
        <div class="demo-accounts">
            <div class="demo-row">
                <span><strong>Admin:</strong> admin@cinema.com</span>
                <span>admin123</span>
            </div>
            <div class="demo-row">
                <span><strong>User:</strong> john@example.com</span>
                <span>john123</span>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
