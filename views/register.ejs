<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register — CinemaPro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --cp-red:#e50914;--cp-red-dark:#b0060f;--cp-gold:#f6c700;
            --cp-dark:#0a0a0f;--cp-card:#14141f;--cp-surface:#1c1c2b;
            --cp-border:rgba(255,255,255,.06);--cp-text:#e2e2e8;--cp-muted:#8b8b9e;
        }
        *{margin:0;padding:0;box-sizing:border-box}
        body{
            background:var(--cp-dark);color:var(--cp-text);font-family:'Inter',sans-serif;
            min-height:100vh;display:flex;align-items:center;justify-content:center;
            position:relative;overflow:hidden;
        }
        h1,h2,h3,h4{font-family:'Outfit',sans-serif}

        .bg-glow{position:absolute;width:400px;height:400px;border-radius:50%;filter:blur(120px);opacity:.08;pointer-events:none}
        .bg-glow.g1{background:var(--cp-gold);top:-100px;right:-100px}
        .bg-glow.g2{background:var(--cp-red);bottom:-100px;left:-100px}

        .auth-card{
            position:relative;z-index:1;
            background:var(--cp-card);border:1px solid var(--cp-border);
            border-radius:24px;padding:2.5rem 2.5rem;width:100%;max-width:440px;
            box-shadow:0 16px 60px rgba(0,0,0,.5);
        }
        .auth-card .brand{text-align:center;margin-bottom:1.5rem}
        .brand-logo{
            font-family:'Outfit',sans-serif;font-weight:900;font-size:1.8rem;
            background:linear-gradient(135deg,var(--cp-red),var(--cp-gold));
            -webkit-background-clip:text;-webkit-text-fill-color:transparent;
            letter-spacing:1.5px;
        }
        .brand p{color:var(--cp-muted);font-size:.9rem;margin-top:.3rem}

        .auth-title{text-align:center;font-weight:700;font-size:1.5rem;color:#fff;margin-bottom:.3rem}
        .auth-subtitle{text-align:center;color:var(--cp-muted);font-size:.9rem;margin-bottom:1.8rem}

        .form-floating>.form-control{
            background:var(--cp-surface);border:1px solid var(--cp-border);
            color:var(--cp-text);border-radius:12px;height:52px;
        }
        .form-floating>.form-control:focus{
            border-color:var(--cp-red);box-shadow:0 0 0 3px rgba(229,9,20,.15);
            background:var(--cp-surface);color:var(--cp-text);
        }
        .form-floating label{color:var(--cp-muted);font-size:.9rem}

        .btn-auth{
            background:linear-gradient(135deg,var(--cp-red),var(--cp-red-dark));
            color:#fff;border:none;border-radius:12px;padding:.85rem;
            font-weight:700;font-size:1rem;width:100%;
            transition:all .25s;box-shadow:0 4px 20px rgba(229,9,20,.3);
        }
        .btn-auth:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(229,9,20,.5);color:#fff}

        .auth-footer{text-align:center;margin-top:1.5rem;font-size:.9rem;color:var(--cp-muted)}
        .auth-footer a{color:var(--cp-red);text-decoration:none;font-weight:600;transition:color .2s}
        .auth-footer a:hover{color:var(--cp-gold)}

        .alert-error{
            background:rgba(229,9,20,.1);border:1px solid rgba(229,9,20,.25);
            border-radius:10px;padding:.8rem 1rem;color:#ff6b6b;
            font-size:.88rem;margin-bottom:1.2rem;text-align:center;
        }

        .password-strength{height:4px;border-radius:2px;background:var(--cp-surface);margin-top:.3rem;overflow:hidden;transition:all .3s}
        .password-strength .bar{height:100%;border-radius:2px;transition:width .3s,background .3s;width:0}

        .back-home{
            position:absolute;top:1.5rem;left:1.5rem;z-index:2;
            color:var(--cp-muted);text-decoration:none;font-size:.9rem;
            display:flex;align-items:center;gap:.3rem;transition:color .2s;
        }
        .back-home:hover{color:#fff}

        @media(max-width:480px){
            .auth-card{margin:1rem;padding:2rem 1.5rem}
        }
    </style>
</head>
<body>
    <div class="bg-glow g1"></div>
    <div class="bg-glow g2"></div>

    <a href="/" class="back-home"><i class="bi bi-arrow-left"></i> Home</a>

    <div class="auth-card">
        <div class="brand">
            <div class="brand-logo"><i class="bi bi-film"></i> CinemaPro</div>
            <p>Your premium cinema experience</p>
        </div>

        <h2 class="auth-title">Create Account</h2>
        <p class="auth-subtitle">Join CinemaPro and start booking movies</p>

        <% if (error) { %>
            <div class="alert-error"><i class="bi bi-exclamation-circle-fill me-1"></i> <%= error %></div>
        <% } %>

        <form method="POST" action="/register" id="registerForm">
            <div class="form-floating mb-3">
                <input type="text" class="form-control" id="name" name="name" placeholder="Full Name" required>
                <label for="name"><i class="bi bi-person-fill me-1"></i> Full Name</label>
            </div>
            <div class="form-floating mb-3">
                <input type="email" class="form-control" id="email" name="email" placeholder="Email" required>
                <label for="email"><i class="bi bi-envelope-fill me-1"></i> Email</label>
            </div>
            <div class="form-floating mb-1">
                <input type="password" class="form-control" id="password" name="password" placeholder="Password" required minlength="4">
                <label for="password"><i class="bi bi-lock-fill me-1"></i> Password</label>
            </div>
            <div class="password-strength mb-3"><div class="bar" id="strengthBar"></div></div>
            <div class="form-floating mb-4">
                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Confirm Password" required>
                <label for="confirmPassword"><i class="bi bi-shield-lock-fill me-1"></i> Confirm Password</label>
            </div>
            <button type="submit" class="btn btn-auth">
                <i class="bi bi-person-plus-fill me-2"></i>Create Account
            </button>
        </form>

        <div class="auth-footer">
            Already have an account? <a href="/login">Sign in</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('password').addEventListener('input', function() {
            const val = this.value;
            const bar = document.getElementById('strengthBar');
            let strength = 0;
            if (val.length >= 4) strength++;
            if (val.length >= 8) strength++;
            if (/[A-Z]/.test(val) && /[0-9]/.test(val)) strength++;
            if (/[^A-Za-z0-9]/.test(val)) strength++;

            const colors = ['#ef4444','#f59e0b','#22c55e','#22c55e'];
            const widths = ['25%','50%','75%','100%'];
            bar.style.width = strength > 0 ? widths[strength-1] : '0';
            bar.style.background = strength > 0 ? colors[strength-1] : 'transparent';
        });
    </script>
</body>
</html>
