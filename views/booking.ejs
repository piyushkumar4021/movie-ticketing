<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Tickets - CinemaPro</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.min.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #e50914;
            --secondary-color: #221f1f;
            --accent-color: #f39c12;
        }

        * {
            scroll-behavior: smooth;
        }

        body {
            background-color: #0f0f0f;
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Navbar Styling */
        .navbar {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border-bottom: 3px solid var(--primary-color);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
            color: var(--primary-color) !important;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .nav-link {
            color: #e0e0e0 !important;
            margin-left: 15px;
            transition: color 0.3s ease;
        }

        .nav-link:hover {
            color: var(--primary-color) !important;
        }

        /* Forms */
        .form-control, .form-select {
            background-color: #2d2d2d;
            border: 1px solid #404040;
            color: #e0e0e0;
        }

        .form-control:focus, .form-select:focus {
            background-color: #2d2d2d;
            border-color: var(--primary-color);
            color: #e0e0e0;
            box-shadow: 0 0 0 0.2rem rgba(229, 9, 20, 0.25);
        }

        .form-label {
            color: #e0e0e0;
            font-weight: 500;
            margin-bottom: 8px;
        }

        /* Booking Container */
        .booking-container {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border: 2px solid #404040;
            border-radius: 12px;
            padding: 40px;
            margin: 40px auto;
            max-width: 700px;
            box-shadow: 0 8px 20px rgba(229, 9, 20, 0.2);
        }

        .booking-header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--primary-color);
        }

        .booking-header h1 {
            color: var(--primary-color);
            font-weight: bold;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .booking-header p {
            color: #b0b0b0;
            font-size: 1.1rem;
        }

        /* Movie Info Card */
        .movie-info {
            background-color: #1a1a1a;
            border: 2px solid var(--primary-color);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 30px;
        }

        .movie-info h3 {
            color: var(--primary-color);
            font-weight: bold;
            margin-bottom: 15px;
        }

        .movie-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .detail-item {
            padding: 10px;
            background-color: #2d2d2d;
            border-radius: 8px;
            border-left: 3px solid var(--primary-color);
        }

        .detail-label {
            color: #b0b0b0;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .detail-value {
            color: var(--primary-color);
            font-weight: bold;
            font-size: 1.1rem;
            margin-top: 5px;
        }

        /* Buttons */
        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            font-weight: bold;
            padding: 12px 30px;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background-color: #c40812;
            transform: scale(1.02);
        }

        .btn-secondary {
            background-color: #404040;
            border: none;
            color: #e0e0e0;
            font-weight: bold;
        }

        .btn-secondary:hover {
            background-color: #505050;
        }

        /* Footer */
        footer {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border-top: 2px solid var(--primary-color);
            padding: 30px 0;
            margin-top: 50px;
            text-align: center;
            color: #b0b0b0;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .booking-container {
                padding: 20px;
                margin: 20px;
            }

            .movie-details {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">🎬 CinemaPro</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#movies">Movies</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin">Admin</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="booking-container">
            <div class="booking-header">
                <h1>Reserve Your Tickets</h1>
                <p>Complete your booking in a few simple steps</p>
            </div>

            <div class="movie-info">
                <h3>📽️ Movie Details</h3>
                <div class="movie-details">
                    <div class="detail-item">
                        <div class="detail-label">Title</div>
                        <div class="detail-value"><%= movie.title %></div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Genre</div>
                        <div class="detail-value"><%= movie.genre %></div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Duration</div>
                        <div class="detail-value"><%= movie.duration %></div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Rating</div>
                        <div class="detail-value"><%= movie.rating %></div>
                    </div>
                </div>
            </div>

            <form id="bookingForm">
                <input type="hidden" name="movieId" value="<%= movie.id %>">

                <div class="mb-3">
                    <label for="name" class="form-label">Full Name <span style="color: var(--primary-color);">*</span></label>
                    <input 
                        type="text" 
                        class="form-control" 
                        id="name" 
                        name="name" 
                        placeholder="Enter your full name"
                        required
                    >
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email Address <span style="color: var(--primary-color);">*</span></label>
                    <input 
                        type="email" 
                        class="form-control" 
                        id="email" 
                        name="email" 
                        placeholder="Enter your email"
                        required
                    >
                </div>

                <div class="mb-4">
                    <label for="seats" class="form-label">Number of Seats <span style="color: var(--primary-color);">*</span></label>
                    <select class="form-select" id="seats" name="seats" required>
                        <option value="">Select number of seats</option>
                        <option value="1">1 Seat - $12</option>
                        <option value="2">2 Seats - $24</option>
                        <option value="3">3 Seats - $36</option>
                        <option value="4">4 Seats - $48</option>
                        <option value="5">5 Seats - $60</option>
                        <option value="6">6 Seats - $72</option>
                        <option value="7">7 Seats - $84</option>
                        <option value="8">8 Seats - $96</option>
                    </select>
                </div>

                <div class="alert alert-info" style="background-color: #2d2d2d; border: 2px solid var(--primary-color); color: var(--primary-color);">
                    <strong>Estimated Total:</strong> <span id="totalPrice">$0</span> 
                    <small style="color: #b0b0b0;">(Price per seat: $12)</small>
                </div>

                <div class="d-grid gap-2 d-sm-flex justify-content-center">
                    <button type="submit" class="btn btn-primary btn-lg" id="payButton">
                        <i class="fas fa-credit-card"></i> Proceed to Payment
                    </button>
                    <a href="/" class="btn btn-secondary btn-lg">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>

    <footer>
        <div class="container">
            <p>&copy; 2026 CinemaPro. All Rights Reserved. | Enjoy Your Movie Experience! 🍿</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.all.min.js"></script>

    <script>
        const seatsSelect = document.getElementById('seats');
        const totalPriceSpan = document.getElementById('totalPrice');

        seatsSelect.addEventListener('change', function() {
            const seats = parseInt(this.value) || 0;
            const totalPrice = seats * 12;
            totalPriceSpan.textContent = '$' + totalPrice;
        });

        // Handle form submission
        const bookingForm = document.getElementById('bookingForm');
        bookingForm.addEventListener('submit', async function(e) {
            e.preventDefault();

            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const seats = document.getElementById('seats').value;
            const movieId = document.querySelector('input[name="movieId"]').value;

            // Validate
            if (!name || !email || !seats) {
                Swal.fire({
                    icon: 'error',
                    title: 'Missing Information',
                    text: 'Please fill in all required fields!',
                    background: '#1a1a1a',
                    color: '#e0e0e0',
                    confirmButtonColor: '#e50914'
                });
                return;
            }

            // Show loading spinner
            Swal.fire({
                title: 'Processing Payment',
                html: '<div class="spinner-border text-danger" role="status"><span class="visually-hidden">Loading...</span></div><p style="margin-top: 15px;">Please wait while we process your payment...</p>',
                background: '#1a1a1a',
                color: '#e0e0e0',
                allowOutsideClick: false,
                allowEscapeKey: false,
                didOpen: async () => {
                    // Simulate payment processing
                    setTimeout(async () => {
                        try {
                            const response = await fetch('/book', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({
                                    movieId: parseInt(movieId),
                                    name: name,
                                    email: email,
                                    seats: seats
                                })
                            });

                            const data = await response.json();

                            if (data.success) {
                                // Show success alert
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Payment Successful!',
                                    text: 'Your tickets have been booked. Redirecting to ticket summary...',
                                    background: '#1a1a1a',
                                    color: '#e0e0e0',
                                    confirmButtonColor: '#e50914',
                                    didClose: () => {
                                        // Redirect to ticket page
                                        window.location.href = `/ticket/${data.bookingId}`;
                                    }
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Booking Failed',
                                    text: data.message || 'An error occurred while booking your tickets.',
                                    background: '#1a1a1a',
                                    color: '#e0e0e0',
                                    confirmButtonColor: '#e50914'
                                });
                            }
                        } catch (error) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'An unexpected error occurred. Please try again.',
                                background: '#1a1a1a',
                                color: '#e0e0e0',
                                confirmButtonColor: '#e50914'
                            });
                        }
                    }, 2000); // Simulate 2-second payment processing
                }
            });
        });
    </script>
</body>
</html>
