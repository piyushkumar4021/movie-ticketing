<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Book your tickets for <%= movie.title %> at CinemaPro — select seats, enter details, and confirm in seconds.">
    <title>Book Tickets — <%= movie.title %> | CinemaPro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.min.css" rel="stylesheet">

    <style>
        :root {
            --cp-red:#e50914;--cp-red-dark:#b0060f;--cp-gold:#f6c700;
            --cp-dark:#0a0a0f;--cp-card:#14141f;--cp-surface:#1c1c2b;
            --cp-border:rgba(255,255,255,.06);--cp-text:#e2e2e8;--cp-muted:#8b8b9e;
        }
        *{margin:0;padding:0;box-sizing:border-box;scroll-behavior:smooth}
        body{background:var(--cp-dark);color:var(--cp-text);font-family:'Inter',sans-serif;overflow-x:hidden}
        h1,h2,h3,h4,h5,h6,.navbar-brand{font-family:'Outfit',sans-serif}

        .navbar{background:rgba(10,10,15,.75)!important;backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border-bottom:1px solid var(--cp-border);padding:.9rem 0}
        .navbar-brand{font-weight:900;font-size:1.55rem;background:linear-gradient(135deg,var(--cp-red),var(--cp-gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:1.5px;text-transform:uppercase}
        .nav-link{color:var(--cp-muted)!important;font-weight:500;transition:color .3s}
        .nav-link:hover{color:#fff!important}

        .booking-hero{
            position:relative;min-height:200px;display:flex;align-items:center;
            background:linear-gradient(to bottom,rgba(10,10,15,.2),var(--cp-dark)),url('<%= movie.image %>') center/cover no-repeat;
            margin-top:62px;
        }
        .booking-hero::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(10,10,15,.5),var(--cp-dark))}
        .booking-hero .container{position:relative;z-index:1}

        .steps{display:flex;justify-content:center;gap:0;margin:2rem 0 2.5rem;position:relative}
        .step{display:flex;align-items:center;gap:.6rem;padding:.6rem 1.4rem;font-size:.88rem;font-weight:600;color:var(--cp-muted);position:relative}
        .step .step-num{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;background:var(--cp-surface);border:2px solid var(--cp-border);transition:all .35s}
        .step.active .step-num{background:var(--cp-red);border-color:var(--cp-red);color:#fff;box-shadow:0 0 16px rgba(229,9,20,.4)}
        .step.active{color:#fff}
        .step.done .step-num{background:#28a745;border-color:#28a745;color:#fff}
        .step-line{width:50px;height:2px;background:var(--cp-border);align-self:center}
        .step-line.active{background:var(--cp-red)}

        .booking-wrap{background:var(--cp-card);border:1px solid var(--cp-border);border-radius:20px;padding:2.5rem;max-width:820px;margin:0 auto 3rem;box-shadow:0 8px 40px rgba(0,0,0,.3)}

        .movie-info-card{background:var(--cp-surface);border:1px solid var(--cp-border);border-radius:14px;padding:1.3rem 1.5rem;margin-bottom:2rem;display:flex;gap:1.5rem;align-items:center}
        .movie-info-card img{width:80px;height:110px;object-fit:cover;border-radius:10px;border:2px solid var(--cp-red)}
        .movie-info-card h4{font-weight:700;color:#fff;margin-bottom:.3rem}
        .movie-info-card .meta-row{display:flex;gap:1rem;font-size:.85rem;color:var(--cp-muted)}
        .movie-info-card .meta-row i{color:var(--cp-red)}

        .seat-section h5{font-weight:700;color:#fff;margin-bottom:1rem}
        .screen{background:linear-gradient(90deg,transparent,var(--cp-red),transparent);height:4px;border-radius:50%;margin:0 auto 2rem;width:70%;opacity:.7}
        .screen-label{text-align:center;font-size:.75rem;color:var(--cp-muted);margin-bottom:.6rem;text-transform:uppercase;letter-spacing:2px}
        .seat-grid{display:flex;flex-direction:column;align-items:center;gap:8px;margin-bottom:1.5rem}
        .seat-row{display:flex;gap:8px;align-items:center}
        .seat-row .row-label{width:20px;text-align:center;font-size:.75rem;color:var(--cp-muted);font-weight:600}
        .seat{
            width:36px;height:36px;border-radius:8px;border:2px solid #333;
            background:var(--cp-surface);cursor:pointer;
            transition:all .2s;display:flex;align-items:center;justify-content:center;
            font-size:.7rem;color:var(--cp-muted);
        }
        .seat:hover:not(.occupied):not(.selected){background:rgba(229,9,20,.15);border-color:var(--cp-red)}
        .seat.selected{background:var(--cp-red);border-color:var(--cp-red);color:#fff;transform:scale(1.1);box-shadow:0 0 14px rgba(229,9,20,.4)}
        .seat.occupied{background:#333;border-color:#444;cursor:not-allowed;opacity:.4}
        .seat-legend{display:flex;justify-content:center;gap:1.5rem;margin-bottom:1.5rem;font-size:.82rem;color:var(--cp-muted)}
        .seat-legend span{display:flex;align-items:center;gap:.4rem}
        .legend-box{width:18px;height:18px;border-radius:4px;border:2px solid #333}
        .legend-box.available{background:var(--cp-surface)}
        .legend-box.sel{background:var(--cp-red);border-color:var(--cp-red)}
        .legend-box.occ{background:#333;border-color:#444;opacity:.4}

        .form-floating>.form-control{background:var(--cp-surface);border:1px solid var(--cp-border);color:var(--cp-text);border-radius:10px}
        .form-floating>.form-control:focus{border-color:var(--cp-red);box-shadow:0 0 0 3px rgba(229,9,20,.15);background:var(--cp-surface);color:var(--cp-text)}
        .form-floating label{color:var(--cp-muted)}

        .price-banner{background:var(--cp-surface);border:1px solid var(--cp-border);border-radius:12px;padding:1.2rem 1.5rem;display:flex;justify-content:space-between;align-items:center;margin:1.5rem 0}
        .price-banner .price-amount{font-family:'Outfit',sans-serif;font-size:1.8rem;font-weight:900;color:var(--cp-red)}

        .btn-pay{background:linear-gradient(135deg,var(--cp-red),var(--cp-red-dark));color:#fff;border:none;border-radius:12px;padding:.9rem 2rem;font-weight:700;font-size:1rem;width:100%;transition:all .25s;box-shadow:0 4px 20px rgba(229,9,20,.3)}
        .btn-pay:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(229,9,20,.5);color:#fff}
        .btn-pay:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
        .btn-cancel{background:var(--cp-surface);color:var(--cp-muted);border:1px solid var(--cp-border);border-radius:12px;padding:.9rem 2rem;font-weight:600;transition:all .2s}
        .btn-cancel:hover{background:#2a2a3a;color:#fff}

        @keyframes shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-8px)}40%,80%{transform:translateX(8px)}}
        .shake{animation:shake .4s ease}

        .nav-user{display:flex;align-items:center;gap:.8rem;margin-left:1rem}
        .user-avatar{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--cp-red),var(--cp-gold));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.82rem;color:#fff;flex-shrink:0}
        .user-name{color:var(--cp-text);font-weight:600;font-size:.88rem;white-space:nowrap}
        .btn-nav-logout{background:var(--cp-surface);border:1px solid var(--cp-border);color:var(--cp-muted);font-size:.78rem;padding:.35rem .9rem;border-radius:8px;text-decoration:none;transition:all .2s}
        .btn-nav-logout:hover{border-color:var(--cp-red);color:#fff}

        .user-info-card{background:var(--cp-surface);border:1px solid var(--cp-border);border-radius:12px;padding:1rem 1.3rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:1rem}
        .user-info-card .ui-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--cp-red),var(--cp-gold));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.1rem;color:#fff;flex-shrink:0}
        .user-info-card .ui-name{color:#fff;font-weight:600;font-size:1rem}
        .user-info-card .ui-email{color:var(--cp-muted);font-size:.82rem}

        footer{background:var(--cp-card);border-top:1px solid var(--cp-border);padding:2rem 0;text-align:center;color:var(--cp-muted);margin-top:3rem;font-size:.9rem}

        @media(max-width:768px){
            .booking-wrap{padding:1.5rem;margin:0 1rem 2rem}
            .seat{width:28px;height:28px;font-size:.6rem}
            .movie-info-card{flex-direction:column;text-align:center}
            .step{padding:.4rem .8rem;font-size:.78rem}
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="bi bi-film"></i> CinemaPro</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#movies">Movies</a></li>
                    <% if (user && user.role === 'admin') { %>
                        <li class="nav-item"><a class="nav-link" href="/admin">Admin</a></li>
                    <% } %>
                </ul>
                <div class="nav-user">
                    <% if (user) { %>
                        <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
                        <span class="user-name d-none d-lg-inline"><%= user.name %></span>
                        <a href="/logout" class="btn-nav-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Backdrop -->
    <div class="booking-hero">
        <div class="container py-4">
            <h2 class="text-white fw-bold" style="font-size:1.6rem"><i class="bi bi-ticket-perforated-fill text-danger me-2"></i>Book Your Tickets</h2>
        </div>
    </div>

    <div class="container">
        <!-- Steps -->
        <div class="steps">
            <div class="step active" id="step1"><span class="step-num">1</span> Select Seats</div>
            <div class="step-line" id="line1"></div>
            <div class="step" id="step2"><span class="step-num">2</span> Confirm & Pay</div>
        </div>

        <div class="booking-wrap">
            <!-- Movie Info -->
            <div class="movie-info-card">
                <img src="<%= movie.image %>" alt="<%= movie.title %>">
                <div>
                    <h4><%= movie.title %></h4>
                    <div class="meta-row">
                        <span><i class="bi bi-tag-fill"></i> <%= movie.genre %></span>
                        <span><i class="bi bi-clock-fill"></i> <%= movie.duration %></span>
                        <span><i class="bi bi-star-fill"></i> <%= movie.rating %></span>
                    </div>
                </div>
            </div>

            <form id="bookingForm">
                <input type="hidden" name="movieId" value="<%= movie.id %>">

                <!-- Section 1: Seats -->
                <div id="seatSection">
                    <div class="seat-section">
                        <h5><i class="bi bi-grid-3x3-gap-fill text-danger me-2"></i>Select Your Seats</h5>
                        <div class="screen-label">Screen</div>
                        <div class="screen"></div>
                        <div class="seat-grid" id="seatGrid"></div>
                        <div class="seat-legend">
                            <span><span class="legend-box available"></span> Available</span>
                            <span><span class="legend-box sel"></span> Selected</span>
                            <span><span class="legend-box occ"></span> Occupied</span>
                        </div>
                    </div>
                    <div class="price-banner">
                        <div>
                            <div style="font-size:.85rem;color:var(--cp-muted)">Selected: <strong id="seatCount" class="text-white">0</strong> seat(s)</div>
                            <div style="font-size:.78rem;color:var(--cp-muted)">$12.00 per seat</div>
                        </div>
                        <div class="price-amount" id="totalPrice">$0</div>
                    </div>
                    <button type="button" class="btn btn-pay" id="btnToDetails" disabled>
                        Continue to Details <i class="bi bi-arrow-right-short"></i>
                    </button>
                </div>

                <!-- Section 2: Confirm & Pay -->
                <div id="detailsSection" class="d-none">
                    <h5 class="mb-3" style="font-weight:700;color:#fff"><i class="bi bi-shield-check text-danger me-2"></i>Confirm Booking</h5>
                    <div class="user-info-card">
                        <div class="ui-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
                        <div>
                            <div class="ui-name"><%= user.name %></div>
                            <div class="ui-email"><%= user.email %></div>
                        </div>
                    </div>
                    <div class="price-banner">
                        <div>
                            <div style="font-size:.85rem;color:var(--cp-muted)">Seats: <strong class="text-white seat-count-mirror">0</strong> | Total</div>
                        </div>
                        <div class="price-amount total-price-mirror">$0</div>
                    </div>
                    <div class="d-flex gap-3 mt-3">
                        <button type="button" class="btn btn-cancel flex-fill" id="btnBackSeats"><i class="bi bi-arrow-left-short"></i> Back</button>
                        <button type="submit" class="btn btn-pay flex-fill" id="payButton">
                            <i class="bi bi-credit-card-fill me-2"></i>Confirm & Pay
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <footer>
        <div class="container">
            <p class="mb-0">&copy; 2026 CinemaPro. All Rights Reserved. | Enjoy Your Movie Experience! 🍿</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.all.min.js"></script>

    <script>
        const rows = 6, cols = 8;
        const rowLabels = ['A','B','C','D','E','F'];
        const seatGrid = document.getElementById('seatGrid');
        let selectedSeats = new Set();
        // Random occupied seats
        const occupied = new Set();
        for (let i = 0; i < 8; i++) {
            occupied.add(Math.floor(Math.random() * rows) + '-' + Math.floor(Math.random() * cols));
        }

        for (let r = 0; r < rows; r++) {
            const rowDiv = document.createElement('div');
            rowDiv.className = 'seat-row';
            rowDiv.innerHTML = '<span class="row-label">' + rowLabels[r] + '</span>';
            for (let c = 0; c < cols; c++) {
                const seat = document.createElement('div');
                seat.className = 'seat';
                seat.dataset.id = r + '-' + c;
                seat.textContent = (c + 1);
                if (occupied.has(r + '-' + c)) {
                    seat.classList.add('occupied');
                    seat.title = 'Occupied';
                } else {
                    seat.addEventListener('click', () => toggleSeat(seat));
                }
                rowDiv.appendChild(seat);
            }
            seatGrid.appendChild(rowDiv);
        }

        function toggleSeat(seat) {
            const id = seat.dataset.id;
            if (selectedSeats.has(id)) {
                selectedSeats.delete(id);
                seat.classList.remove('selected');
            } else {
                if (selectedSeats.size >= 8) {
                    Swal.fire({icon:'warning',title:'Maximum 8 seats',text:'You can select up to 8 seats per booking.',background:'#14141f',color:'#e2e2e8',confirmButtonColor:'#e50914'});
                    return;
                }
                selectedSeats.add(id);
                seat.classList.add('selected');
            }
            updatePrice();
        }

        let currentDisplayPrice = 0;
        function updatePrice() {
            const count = selectedSeats.size;
            const total = count * 12;
            document.getElementById('seatCount').textContent = count;
            document.querySelectorAll('.seat-count-mirror').forEach(e => e.textContent = count);
            document.getElementById('btnToDetails').disabled = count === 0;

            // Animate price
            animateValue('totalPrice', currentDisplayPrice, total, 300);
            document.querySelectorAll('.total-price-mirror').forEach(el => {
                el.textContent = '$' + total;
            });
            currentDisplayPrice = total;
        }

        function animateValue(elId, start, end, duration) {
            const el = document.getElementById(elId);
            const range = end - start;
            const startTime = performance.now();
            function step(now) {
                const elapsed = now - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const val = Math.round(start + range * eased);
                el.textContent = '$' + val;
                if (progress < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
        }

        const btnToDetails = document.getElementById('btnToDetails');
        const btnBackSeats = document.getElementById('btnBackSeats');
        const seatSection = document.getElementById('seatSection');
        const detailsSection = document.getElementById('detailsSection');

        btnToDetails.addEventListener('click', () => {
            seatSection.classList.add('d-none');
            detailsSection.classList.remove('d-none');
            document.getElementById('step1').classList.remove('active');
            document.getElementById('step1').classList.add('done');
            document.getElementById('step2').classList.add('active');
            document.getElementById('line1').classList.add('active');
        });

        btnBackSeats.addEventListener('click', () => {
            detailsSection.classList.add('d-none');
            seatSection.classList.remove('d-none');
            document.getElementById('step2').classList.remove('active');
            document.getElementById('step1').classList.remove('done');
            document.getElementById('step1').classList.add('active');
            document.getElementById('line1').classList.remove('active');
        });

        document.getElementById('bookingForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const seats = selectedSeats.size;
            const movieId = document.querySelector('input[name="movieId"]').value;

            // Activate step 2 as done
            document.getElementById('step2').classList.remove('active');
            document.getElementById('step2').classList.add('done');

            Swal.fire({
                title:'Processing Payment',
                html:'<div class="spinner-border text-danger" role="status"></div><p class="mt-3" style="color:#8b8b9e">Securing your seats…</p>',
                background:'#14141f',color:'#e2e2e8',allowOutsideClick:false,allowEscapeKey:false,showConfirmButton:false,
                didOpen: () => {
                    setTimeout(async () => {
                        try {
                            const res = await fetch('/book', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({movieId:parseInt(movieId),seats})});
                            const data = await res.json();
                            if (data.success) {
                                Swal.fire({icon:'success',title:'Payment Successful!',text:'Redirecting to your ticket…',background:'#14141f',color:'#e2e2e8',confirmButtonColor:'#e50914',timer:2000,timerProgressBar:true,didClose:()=>{window.location.href='/ticket/'+data.bookingId}});
                            } else {
                                Swal.fire({icon:'error',title:'Booking Failed',text:data.message,background:'#14141f',color:'#e2e2e8',confirmButtonColor:'#e50914'});
                            }
                        } catch(err) {
                            Swal.fire({icon:'error',title:'Error',text:'An unexpected error occurred.',background:'#14141f',color:'#e2e2e8',confirmButtonColor:'#e50914'});
                        }
                    }, 2000);
                }
            });
        });
    </script>
</body>
</html>
