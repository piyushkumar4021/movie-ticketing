<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Your booking confirmation for <%= booking.movieTitle %> at CinemaPro.">
    <title>Booking Confirmed — CinemaPro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.min.css" rel="stylesheet">

    <style>
        :root {
            --cp-red:#e50914;--cp-red-dark:#b0060f;--cp-gold:#f6c700;
            --cp-dark:#0a0a0f;--cp-card:#14141f;--cp-surface:#1c1c2b;
            --cp-border:rgba(255,255,255,.06);--cp-text:#e2e2e8;--cp-muted:#8b8b9e;
        }
        *{margin:0;padding:0;box-sizing:border-box}
        body{background:var(--cp-dark);color:var(--cp-text);font-family:'Inter',sans-serif;overflow-x:hidden}
        h1,h2,h3,h4,h5,h6,.navbar-brand{font-family:'Outfit',sans-serif}

        .navbar{background:rgba(10,10,15,.75)!important;backdrop-filter:blur(18px);border-bottom:1px solid var(--cp-border);padding:.9rem 0}
        .navbar-brand{font-weight:900;font-size:1.55rem;background:linear-gradient(135deg,var(--cp-red),var(--cp-gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:1.5px;text-transform:uppercase}
        .nav-link{color:var(--cp-muted)!important;font-weight:500;transition:color .3s}
        .nav-link:hover{color:#fff!important}

        #confettiCanvas{position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:9999}

        .ticket-outer{max-width:560px;margin:120px auto 3rem;position:relative}
        .ticket-card{
            background:var(--cp-card);border:1px solid var(--cp-border);border-radius:20px;
            overflow:hidden;box-shadow:0 12px 50px rgba(0,0,0,.4);
            opacity:0;transform:translateY(60px) scale(.95);
            animation:ticketIn .8s .3s cubic-bezier(.22,1,.36,1) forwards;
        }
        @keyframes ticketIn{to{opacity:1;transform:translateY(0) scale(1)}}

        .ticket-card::before,.ticket-card::after{
            content:'';position:absolute;width:28px;height:28px;background:var(--cp-dark);
            border-radius:50%;top:50%;z-index:2;
        }
        .ticket-card::before{left:-14px}
        .ticket-card::after{right:-14px}

        .ticket-top{background:linear-gradient(135deg,var(--cp-red),var(--cp-red-dark));padding:2rem;text-align:center}
        .checkmark-circle{
            width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,.15);
            display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;
        }
        .checkmark-svg{width:40px;height:40px}
        .checkmark-svg path{
            stroke:#fff;stroke-width:3;fill:none;
            stroke-dasharray:48;stroke-dashoffset:48;
            animation:drawCheck .6s .8s ease forwards;
        }
        @keyframes drawCheck{to{stroke-dashoffset:0}}
        .ticket-top h2{color:#fff;font-weight:700;font-size:1.6rem;margin-bottom:.3rem}
        .ticket-top p{color:rgba(255,255,255,.7);font-size:.9rem}

        .ticket-dashed{border-top:2px dashed var(--cp-border);margin:0 1.5rem}
        .ticket-body{padding:1.8rem 2rem}

        .info-block{margin-bottom:1.3rem}
        .info-block h6{color:var(--cp-muted);font-size:.72rem;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:.6rem}
        .info-row{display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--cp-border)}
        .info-row:last-child{border-bottom:none}
        .info-label{color:var(--cp-muted);font-size:.88rem}
        .info-value{color:#fff;font-weight:600;font-size:.88rem}
        .info-value.highlight{color:var(--cp-red);font-weight:700;font-size:1.1rem}

        .conf-code{
            background:var(--cp-surface);border:1px solid var(--cp-border);border-radius:12px;
            padding:1.2rem;text-align:center;margin:1.5rem 0;
        }
        .conf-code .label{font-size:.72rem;text-transform:uppercase;letter-spacing:2px;color:var(--cp-muted)}
        .conf-code .code{
            font-family:'JetBrains Mono',monospace;font-size:1.6rem;font-weight:700;
            color:var(--cp-gold);letter-spacing:3px;margin-top:.4rem;
        }

        .qr-section{text-align:center;margin-top:1.5rem}
        .qr-section canvas{border-radius:10px;background:#fff;padding:8px}
        .qr-section p{font-size:.75rem;color:var(--cp-muted);margin-top:.5rem}

        .ticket-actions{display:flex;gap:.8rem;margin-top:1.5rem;flex-wrap:wrap;justify-content:center}
        .btn-action{
            background:var(--cp-surface);border:1px solid var(--cp-border);color:var(--cp-text);
            border-radius:10px;padding:.7rem 1.5rem;font-weight:600;font-size:.88rem;
            transition:all .25s;display:flex;align-items:center;gap:.5rem;
        }
        .btn-action:hover{background:var(--cp-red);border-color:var(--cp-red);color:#fff;transform:translateY(-2px)}
        .btn-action.primary{background:var(--cp-red);border-color:var(--cp-red);color:#fff}
        .btn-action.primary:hover{background:var(--cp-red-dark)}

        .alert-note{background:var(--cp-surface);border:1px solid rgba(246,199,0,.2);border-radius:10px;padding:1rem 1.3rem;font-size:.85rem;color:var(--cp-gold);margin-top:1.5rem}

        footer{background:var(--cp-card);border-top:1px solid var(--cp-border);padding:2rem 0;text-align:center;color:var(--cp-muted);margin-top:3rem;font-size:.9rem}

        .nav-user{display:flex;align-items:center;gap:.8rem;margin-left:1rem}
        .user-avatar{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--cp-red),var(--cp-gold));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.82rem;color:#fff;flex-shrink:0}
        .user-name{color:var(--cp-text);font-weight:600;font-size:.88rem;white-space:nowrap}
        .btn-nav-logout{background:var(--cp-surface);border:1px solid var(--cp-border);color:var(--cp-muted);font-size:.78rem;padding:.35rem .9rem;border-radius:8px;text-decoration:none;transition:all .2s}
        .btn-nav-logout:hover{border-color:var(--cp-red);color:#fff}

        @media print{
            .navbar,footer,.ticket-actions,.no-print{display:none!important}
            body{background:#fff;color:#000}
            .ticket-card{box-shadow:none;border:2px solid #000}
            .ticket-top{background:var(--cp-red)!important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
            .info-value,.conf-code .code{color:#000}
        }

        @media(max-width:768px){
            .ticket-outer{margin:100px 1rem 2rem}
            .ticket-body{padding:1.2rem}
        }
    </style>
</head>
<body>
    <canvas id="confettiCanvas"></canvas>

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="bi bi-film"></i> CinemaPro</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#movies">Movies</a></li>
                    <% if (user && user.role === 'admin') { %>
                        <li class="nav-item"><a class="nav-link" href="/admin">Admin</a></li>
                    <% } %>
                </ul>
                <div class="nav-user">
                    <% if (user) { %>
                        <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
                        <span class="user-name d-none d-lg-inline"><%= user.name %></span>
                        <a href="/logout" class="btn-nav-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="ticket-outer">
            <div class="ticket-card" id="ticketCard">
                <div class="ticket-top">
                    <div class="checkmark-circle">
                        <svg class="checkmark-svg" viewBox="0 0 40 40">
                            <path d="M10 20 L17 28 L30 12"/>
                        </svg>
                    </div>
                    <h2>Booking Confirmed!</h2>
                    <p>Your seats are reserved and ready</p>
                </div>

                <div class="ticket-dashed"></div>

                <div class="ticket-body">
                    <div class="info-block">
                        <h6><i class="bi bi-film me-1"></i> Movie</h6>
                        <div class="info-row">
                            <span class="info-label">Title</span>
                            <span class="info-value"><%= booking.movieTitle %></span>
                        </div>
                    </div>

                    <div class="info-block">
                        <h6><i class="bi bi-person-fill me-1"></i> Guest</h6>
                        <div class="info-row">
                            <span class="info-label">Name</span>
                            <span class="info-value"><%= booking.name %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Email</span>
                            <span class="info-value"><%= booking.email %></span>
                        </div>
                    </div>

                    <div class="info-block">
                        <h6><i class="bi bi-ticket-perforated-fill me-1"></i> Ticket</h6>
                        <div class="info-row">
                            <span class="info-label">Seats</span>
                            <span class="info-value"><%= booking.seats %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Price / Seat</span>
                            <span class="info-value">₹<%= seatPrice %></span>
                        </div>
                    </div>

                    <div class="conf-code">
                        <div class="label">Confirmation Number</div>
                        <div class="code"><%= booking._id.toString().slice(-8).toUpperCase() %></div>
                    </div>

                    <div class="info-block">
                        <h6><i class="bi bi-credit-card-fill me-1"></i> Payment</h6>
                        <div class="info-row">
                            <span class="info-label">Subtotal</span>
                            <span class="info-value">₹<%= booking.totalPrice.toFixed(2) %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Tax (incl.)</span>
                            <span class="info-value">₹0.00</span>
                        </div>
                        <div class="info-row" style="padding-top:.8rem;margin-top:.4rem;border-top:1px solid var(--cp-border)">
                            <span class="info-label" style="font-weight:700;color:#fff">Total Paid</span>
                            <span class="info-value highlight">₹<%= booking.totalPrice.toFixed(2) %></span>
                        </div>
                        <% if (booking.razorpayPaymentId) { %>
                        <div class="info-row">
                            <span class="info-label">Payment ID</span>
                            <span class="info-value" style="font-size:.78rem;color:var(--cp-gold)"><%= booking.razorpayPaymentId %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Status</span>
                            <span class="info-value" style="color:#28a745"><i class="bi bi-check-circle-fill me-1"></i><%= booking.paymentStatus.toUpperCase() %></span>
                        </div>
                        <% } %>
                    </div>

                    <div class="info-block">
                        <h6><i class="bi bi-calendar-event-fill me-1"></i> Booking</h6>
                        <div class="info-row">
                            <span class="info-label">Date</span>
                            <span class="info-value"><%= booking.bookingDate %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Time</span>
                            <span class="info-value"><%= booking.bookingTime %></span>
                        </div>
                    </div>

                    <!-- QR Code -->
                    <div class="qr-section">
                        <canvas id="qrCode"></canvas>
                        <p>Scan at entrance for quick entry</p>
                    </div>

                    <div class="alert-note">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Important:</strong> Please arrive 15 minutes early. Bring valid ID for verification.
                    </div>

                    <div class="ticket-actions no-print">
                        <a href="/" class="btn-action primary"><i class="bi bi-house-fill"></i> Home</a>
                        <button class="btn-action" onclick="window.print()"><i class="bi bi-printer-fill"></i> Print</button>
                        <button class="btn-action" id="downloadBtn"><i class="bi bi-download"></i> Download</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="no-print">
        <div class="container">
            <p class="mb-0">&copy; 2026 CinemaPro. All Rights Reserved. | Enjoy Your Movie Experience! 🍿</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.all.min.js"></script>
    <!-- QR Code lib -->
    <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
    <!-- html2canvas for download -->
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>

    <script>
        QRCode.toCanvas(document.getElementById('qrCode'), 'CINEMAPRO-<%= booking._id %>', {
            width: 130, margin: 1,
            color: { dark: '#0a0a0f', light: '#ffffff' }
        });

        (function(){
            const canvas = document.getElementById('confettiCanvas');
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            window.addEventListener('resize',()=>{canvas.width=innerWidth;canvas.height=innerHeight});

            const colors = ['#e50914','#f6c700','#ff6b6b','#4ecdc4','#a855f7','#fff'];
            const confetti = [];

            for(let i=0;i<180;i++){
                confetti.push({
                    x: Math.random()*canvas.width,
                    y: Math.random()*canvas.height - canvas.height,
                    w: 6+Math.random()*6,
                    h: 3+Math.random()*4,
                    color: colors[Math.floor(Math.random()*colors.length)],
                    speedX: (Math.random()-.5)*3,
                    speedY: Math.random()*4+2,
                    rotation: Math.random()*360,
                    rotSpeed: (Math.random()-.5)*8,
                    opacity: .7+Math.random()*.3
                });
            }

            let frame = 0;
            function draw(){
                ctx.clearRect(0,0,canvas.width,canvas.height);
                frame++;
                confetti.forEach(c=>{
                    c.x += c.speedX + Math.sin(frame*.02)*.3;
                    c.y += c.speedY;
                    c.rotation += c.rotSpeed;
                    if(c.y > canvas.height+20){c.opacity -= .02;}
                    if(c.opacity <= 0) return;
                    ctx.save();
                    ctx.globalAlpha = c.opacity;
                    ctx.translate(c.x,c.y);
                    ctx.rotate(c.rotation*Math.PI/180);
                    ctx.fillStyle = c.color;
                    ctx.fillRect(-c.w/2,-c.h/2,c.w,c.h);
                    ctx.restore();
                });
                if(confetti.some(c=>c.opacity>0)){
                    requestAnimationFrame(draw);
                } else {
                    canvas.remove();
                }
            }
            draw();
        })();

        document.getElementById('downloadBtn').addEventListener('click', async ()=>{
            const ticket = document.getElementById('ticketCard');
            try {
                const c = await html2canvas(ticket, {backgroundColor:'#0a0a0f',scale:2});
                const link = document.createElement('a');
                link.download = 'CinemaPro-Ticket-<%= booking._id.toString().slice(-8).toUpperCase() %>.png';
                link.href = c.toDataURL();
                link.click();
            } catch(e) {
                Swal.fire({icon:'error',title:'Download Failed',text:'Could not generate image.',background:'#14141f',color:'#e2e2e8',confirmButtonColor:'#e50914'});
            }
        });
    </script>
</body>
</html>
