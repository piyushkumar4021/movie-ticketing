<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking Confirmation - CinemaPro</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.min.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #e50914;
            --secondary-color: #221f1f;
            --accent-color: #f39c12;
        }

        * {
            scroll-behavior: smooth;
        }

        body {
            background-color: #0f0f0f;
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Navbar Styling */
        .navbar {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border-bottom: 3px solid var(--primary-color);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
            color: var(--primary-color) !important;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .nav-link {
            color: #e0e0e0 !important;
            margin-left: 15px;
            transition: color 0.3s ease;
        }

        .nav-link:hover {
            color: var(--primary-color) !important;
        }

        /* Ticket Styling */
        .ticket-container {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border: 3px dashed var(--primary-color);
            border-radius: 15px;
            padding: 40px;
            max-width: 600px;
            margin: 40px auto;
            box-shadow: 0 8px 20px rgba(229, 9, 20, 0.3);
        }

        .ticket-header {
            text-align: center;
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .ticket-header .checkmark {
            font-size: 4rem;
            margin-bottom: 15px;
            animation: bounceIn 0.6s ease;
        }

        .ticket-header h1 {
            color: var(--primary-color);
            font-size: 2.5rem;
            margin-top: 15px;
            font-weight: bold;
        }

        .ticket-header p {
            color: #b0b0b0;
            margin-top: 10px;
        }

        .ticket-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #404040;
        }

        .ticket-row:last-child {
            border-bottom: none;
        }

        .ticket-label {
            color: #b0b0b0;
            font-weight: 500;
        }

        .ticket-value {
            color: var(--primary-color);
            font-weight: bold;
        }

        .ticket-divider {
            border: 1px dashed var(--primary-color);
            margin: 20px 0;
        }

        .confirmation-code {
            background-color: #1a1a1a;
            border: 2px solid var(--primary-color);
            padding: 15px;
            text-align: center;
            border-radius: 8px;
            margin: 20px 0;
        }

        .confirmation-code-label {
            color: #b0b0b0;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .confirmation-code-value {
            color: var(--primary-color);
            font-size: 1.8rem;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            margin-top: 10px;
            letter-spacing: 2px;
        }

        /* Buttons */
        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            font-weight: bold;
            padding: 12px 30px;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background-color: #c40812;
            transform: scale(1.02);
        }

        .btn-secondary {
            background-color: #404040;
            border: none;
            color: #e0e0e0;
            font-weight: bold;
        }

        .btn-secondary:hover {
            background-color: #505050;
        }

        /* Footer */
        footer {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            border-top: 2px solid var(--primary-color);
            padding: 30px 0;
            margin-top: 50px;
            text-align: center;
            color: #b0b0b0;
        }

        /* Animations */
        @keyframes bounceIn {
            0% {
                opacity: 0;
                transform: scale(0.3);
            }
            50% {
                opacity: 1;
                transform: scale(1.05);
            }
            100% {
                transform: scale(1);
            }
        }

        .ticket-info {
            background-color: #1a1a1a;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid var(--primary-color);
        }

        .ticket-info h3 {
            color: var(--primary-color);
            margin-bottom: 15px;
            font-size: 1.2rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .ticket-container {
                padding: 20px;
                margin: 20px;
            }

            .ticket-header h1 {
                font-size: 1.8rem;
            }

            .ticket-header .checkmark {
                font-size: 2.5rem;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">🎬 CinemaPro</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#movies">Movies</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin">Admin</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="ticket-container">
            <div class="ticket-header">
                <div class="checkmark">✅</div>
                <h1>Booking Confirmed!</h1>
                <p>Your tickets have been successfully reserved</p>
            </div>

            <div class="ticket-info">
                <h3>📽️ Movie Information</h3>
                <div class="ticket-row">
                    <span class="ticket-label">Movie Title:</span>
                    <span class="ticket-value"><%= booking.movieTitle %></span>
                </div>
            </div>

            <div class="ticket-info">
                <h3>👤 Booking Details</h3>
                <div class="ticket-row">
                    <span class="ticket-label">Name:</span>
                    <span class="ticket-value"><%= booking.name %></span>
                </div>
                <div class="ticket-row">
                    <span class="ticket-label">Email:</span>
                    <span class="ticket-value"><%= booking.email %></span>
                </div>
            </div>

            <div class="ticket-info">
                <h3>🎟️ Ticket Information</h3>
                <div class="ticket-row">
                    <span class="ticket-label">Number of Seats:</span>
                    <span class="ticket-value"><%= booking.seats %></span>
                </div>
                <div class="ticket-row">
                    <span class="ticket-label">Price Per Seat:</span>
                    <span class="ticket-value">$12.00</span>
                </div>
            </div>

            <div class="confirmation-code">
                <div class="confirmation-code-label">Your Confirmation Number</div>
                <div class="confirmation-code-value">BOOK-<%= String(booking.id).padStart(5, '0') %></div>
            </div>

            <div class="ticket-info">
                <h3>💳 Payment Summary</h3>
                <div class="ticket-row">
                    <span class="ticket-label">Subtotal:</span>
                    <span class="ticket-value">$<%= (booking.seats * 12).toFixed(2) %></span>
                </div>
                <div class="ticket-row">
                    <span class="ticket-label">Tax (10%):</span>
                    <span class="ticket-value">$<%= (booking.seats * 12 * 0.1).toFixed(2) %></span>
                </div>
                <div class="ticket-divider"></div>
                <div class="ticket-row" style="padding: 15px 0; font-size: 1.2rem;">
                    <span class="ticket-label">Total Amount Paid:</span>
                    <span class="ticket-value">$<%= (booking.seats * 12 * 1.1).toFixed(2) %></span>
                </div>
            </div>

            <div class="ticket-info">
                <h3>📅 Booking Information</h3>
                <div class="ticket-row">
                    <span class="ticket-label">Booking Date:</span>
                    <span class="ticket-value"><%= booking.bookingDate %></span>
                </div>
                <div class="ticket-row">
                    <span class="ticket-label">Booking Time:</span>
                    <span class="ticket-value"><%= booking.bookingTime %></span>
                </div>
            </div>

            <div class="alert alert-warning" style="background-color: #2d2d2d; border: 2px solid var(--accent-color); color: var(--accent-color); margin-top: 20px;">
                <strong>⚠️ Important:</strong> Please arrive at least 15 minutes before the show time. Bring valid ID for identity verification.
            </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-center mt-4">
                <a href="/" class="btn btn-secondary btn-lg">
                    Back to Home
                </a>
            </div>
        </div>
    </div>

    <footer>
        <div class="container">
            <p>&copy; 2026 CinemaPro. All Rights Reserved. | Enjoy Your Movie Experience! 🍿</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.28/dist/sweetalert2.all.min.js"></script>

    <script>
        window.addEventListener('load', function() {
            Swal.fire({
                icon: 'success',
                title: 'Tickets Booked Successfully!',
                text: 'Your booking confirmation has been saved. Check your email for details.',
                background: '#1a1a1a',
                color: '#e0e0e0',
                confirmButtonColor: '#e50914',
                timer: 3000,
                timerProgressBar: true
            });
        });
    </script>
</body>
</html>
