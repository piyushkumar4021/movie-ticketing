<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page Not Found - CinemaPro</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #e50914;
            --secondary-color: #221f1f;
            --accent-color: #f39c12;
        }

        body {
            background-color: #0f0f0f;
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .error-container {
            text-align: center;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            padding: 60px 40px;
            border-radius: 12px;
            border: 2px solid var(--primary-color);
            box-shadow: 0 8px 20px rgba(229, 9, 20, 0.3);
            max-width: 600px;
        }

        .error-code {
            font-size: 5rem;
            font-weight: bold;
            color: var(--primary-color);
            margin-bottom: 20px;
        }

        .error-title {
            font-size: 2rem;
            margin-bottom: 15px;
            color: #e0e0e0;
        }

        .error-message {
            font-size: 1.1rem;
            color: #b0b0b0;
            margin-bottom: 30px;
        }

        .btn-home {
            background-color: var(--primary-color);
            border: none;
            color: white;
            font-weight: bold;
            padding: 12px 30px;
            transition: all 0.3s ease;
        }

        .btn-home:hover {
            background-color: #c40812;
            transform: scale(1.02);
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-code">404</div>
        <div class="error-title">Oops! Page Not Found</div>
        <p class="error-message"><%= message || 'The page you are looking for does not exist. It might have been moved or deleted.' %></p>
        <a href="/" class="btn btn-home btn-lg">
            🏠 Back to Home
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
